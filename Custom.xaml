            <!-- 第二行 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,0">
                <local:MyButton Margin="0,0,10,0" Width="140" Height="35"
                            Text="📦 资源下载" EventType="打开网页"
                            EventData="https://wtumc.fun/resources"
                            ToolTip="Mod、光影、材质包等" />
                <local:MyButton Margin="0,0,10,0" Width="140" Height="35"
                            Text="🔧 工具箱" EventType="打开网页"
                            EventData="https://wtumc.fun/tools"
                            ToolTip="MOTD预览·附魔计算·种子地图" />
                <local:MyButton Width="140" Height="35" ColorType="Red"
                            Text="⭐ Star 项目" EventType="打开网页"
                            EventData="https://github.com/SARICE233/WTUMCweb-1.0-alpha"
                            ToolTip="去 GitHub 给项目点个 Star！" />
            </StackPanel>
        </StackPanel>
    </local:MyCard>

