    <!-- ═══════════════════════════════════════════════════════ -->
    <local:MyCard Title="快捷入口" Margin="0,0,0,12">
        <StackPanel Margin="25,30,23,18">
            <!-- 第一行 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <local:MyButton Margin="0,0,10,0" Width="140" Height="35" ColorType="Highlight"
                            Text="🌐 社区官网" EventType="打开网页"
                            EventData="https://wtumc.fun"
                            ToolTip="打开 WTU-MC 官方网站" />
