<!--
  武汉纺织大学 Minecraft 社区 × PCL2 自定义主页
  WTU-MC Community · wtumc.fun

  → 设置 → 个性化 → 主页 → 读取本地文件 → 选择此文件
  出问题直接删掉这个文件即可恢复默认。
-->

<!-- ═══════════════════════════════════════════════════════ -->
<!-- 服务器卡片 — 最核心的信息放最前面 -->
<!-- ═══════════════════════════════════════════════════════ -->
    <local:MyCard Title="武汉纺织大学 Minecraft 社区" Margin="0,0,0,12">
        <StackPanel Margin="25,30,23,18">
            <!-- 标语 -->
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" HorizontalAlignment="Center"
                       FontSize="14" Foreground="{DynamicResource ColorBrush5}"
                       Text="像素之外 / 无限之境" />
            <TextBlock TextWrapping="Wrap" Margin="0,0,0,14" HorizontalAlignment="Center"
                       FontSize="11" Foreground="{DynamicResource ColorBrush3}"
                       Text="在指尖上织就世界，在虚拟中纵横经纬" />

            <!-- 主服务器按钮行 — 模糊匹配本地 1.21.1 任意 Loader -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <local:MyButton Margin="0,0,12,0" Width="200" Height="38" ColorType="Highlight"
                            Text="🎮 加入服务器" EventType="启动游戏"
                            EventData="1.21.11|mc.wtumc.fun"
                            ToolTip="模糊匹配本地 1.21.x 版本，直连服务器" />
                <local:MyButton Width="155" Height="38"
                            Text="📋 复制地址" EventType="复制文本"
                            EventData="mc.wtumc.fun"
                            ToolTip="复制服务器 IP 到剪贴板" />
            </StackPanel>

            <!-- 服务器地址 — 原版纯净服 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <local:MyTextButton Margin="0,0,0,0" HorizontalAlignment="Center"
                            Text="服务器地址：mc.wtumc.fun（点击复制）" EventType="复制文本"
                            EventData="mc.wtumc.fun"
                            ToolTip="点击复制服务器地址" />
            </StackPanel>

            <local:MyHint Margin="0,12,0,0" Theme="Blue"
                        Text="服务器状态、在线人数、版本信息可在官网 https://wtumc.fun 实时查看" />
        </StackPanel>
    </local:MyCard>

    <!-- ═══════════════════════════════════════════════════════ -->
    <!-- PCL 本机功能 — 优先级第二，启动器自带实用功能 -->
    <!-- ═══════════════════════════════════════════════════════ -->
    <local:MyCard Title="本机功能" Margin="0,0,0,12">
        <StackPanel Margin="25,30,23,18">
            <!-- 第一行：核心维护 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <local:MyButton Margin="0,0,10,0" Width="155" Height="35" ColorType="Highlight"
                            Text="🧹 清理垃圾" EventType="清理垃圾"
                            ToolTip="清理 Minecraft 日志与缓存文件" />
                <local:MyButton Margin="0,0,10,0" Width="155" Height="35"
                            Text="⚡ 内存优化" EventType="内存优化"
                            ToolTip="一键优化 JVM 内存参数" />
                <local:MyButton Width="155" Height="35" ColorType="Red"
                            Text="🔄 刷新主页" EventType="刷新页面"
                            ToolTip="重新加载自定义主页" />
            </StackPanel>

            <!-- 第二行：启动基岩版 — 通过 minecraft:// 协议唤起（方案来源：MFN233 主页 / PCL Discussion #3636） -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <local:MyButton Width="240" Height="38" ColorType="Highlight"
                            Text="🪨 启动 Minecraft 基岩版" EventType="打开网页"
                            EventData="minecraft://"
                            ToolTip="通过 URL Scheme 唤起本机已安装的基岩版 Minecraft" />
            </StackPanel>

            <!-- 第三行：今日人品 → PCL 原生功能，随机生成每日人品值 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <local:MyButton Width="240" Height="38" ColorType="Highlight"
                            Text="🎲 今日人品" EventType="今日人品"
                            ToolTip="测测今天运气如何！" />
            </StackPanel>

            <!-- 第四行：快捷目录 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <local:MyButton Margin="0,0,10,0" Width="115" Height="33"
                            Text="📁 .minecraft" EventType="打开文件"
                            EventData="explorer.exe|.minecraft"
                            ToolTip="打开 .minecraft 文件夹" />
                <local:MyButton Margin="0,0,10,0" Width="115" Height="33"
                            Text="📂 versions" EventType="打开文件"
                            EventData="explorer.exe|.minecraft\versions"
                            ToolTip="打开版本文件夹" />
                <local:MyButton Margin="0,0,10,0" Width="115" Height="33"
                            Text="📦 mods" EventType="打开文件"
                            EventData="explorer.exe|.minecraft\mods"
                            ToolTip="打开 Mod 文件夹" />
                <local:MyButton Width="115" Height="33"
                            Text="🎯 saves" EventType="打开文件"
                            EventData="explorer.exe|.minecraft\saves"
                            ToolTip="打开存档文件夹" />
            </StackPanel>

            <!-- 第五行：帮助入口 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <local:MyTextButton Margin="0,0,0,0" HorizontalAlignment="Center"
                            Text="📖 PCL 帮助文档" EventType="打开帮助"
                            EventData="帮助/自定义帮助.json"
                            ToolTip="打开 PCL 帮助文档" />
            </StackPanel>
        </StackPanel>
    </local:MyCard>

    <!-- ═══════════════════════════════════════════════════════ -->
