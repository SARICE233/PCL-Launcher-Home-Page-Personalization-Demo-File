                            Text="💬 QQ 群" EventType="打开网页"
                            EventData="https://qm.qq.com/q/mTdePIDrH2"
                            ToolTip="加入纺大 MC 社区 QQ 群" />
                <local:MyButton Width="140" Height="35"
